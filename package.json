{
  "name": "tokenman",
  "version": "0.0.1",
  "description": "File-based token counter CLI powered by tiktoken",
  "type": "module",
  "bin": {
    "tkm": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "biome check --write .",
    "check:type": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "fast-glob": "^3.3.3",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "yungblud",
    "url": "https://github.com/yungblud"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yungblud/tokenman.git"
  },
  "bugs": {
    "url": "https://github.com/yungblud/tokenman/issues"
  },
  "homepage": "https://github.com/yungblud/tokenman#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT"
}
